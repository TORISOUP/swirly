{
  "name": "swirly",
  "description": "A marble diagram generator.",
  "version": "0.22.0-torisoup.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TORISOUP/swirly.git",
    "directory": "packages/swirly"
  },
  "homepage": "https://github.com/TORISOUP/swirly#readme",
  "author": {
    "name": "TORISOUP"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "bin": {
    "swirly": "dist/cli.js"
  },
  "scripts": {
    "build": "yarn run clean && ../../scripts/build-ts.sh",
