    "@swirly/renderer-node": "0.22.0-torisoup.0",
    "@swirly/theme-default-dark": "0.22.0-torisoup.0",
    "@swirly/theme-default-light": "0.22.0-torisoup.0",
    "js-yaml": "^4.0.0",
    "source-map-support": "^0.5.19",
    "stream-to-promise": "^3.0.0",
    "svgo": "^3.0.2",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@swirly/types": "0.22.0-torisoup.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^16",
    "@types/stream-to-promise": "^2.2.1",
    "@types/svgo": "^3.0.0",
    "@types/yargs": "^17.0.10",
    "shx": "^0.3.4"
  },
  "funding": {
    "type": "github",
